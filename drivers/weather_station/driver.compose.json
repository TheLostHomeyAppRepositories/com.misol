    "energy": {
        "batteries": [
            "AA",
            "AA"
        ]
    },
    "pair": [
        {
            "id": "list_my_devices",
            "template": "list_devices",
            "navigation": {
                "next": "add_my_devices"
            }
        },
        {
            "id": "add_my_devices",
            "template": "add_devices"
        }
    ],
    "settings": [
        {
            "id": "gatewayID",
            "type": "label",
            "label": {
                "en": "Gateway ID"
            },
            "value": "",
            "hint": {
                "en": "Shows the ID of the gateway.",
                "de": "Zeigt die ID des Gateways."
            }
        },
        {
            "id": "stationType",
            "type": "label",
            "label": {
                "en": "Gateway Type",
                "de": "Gateway-Typ"
            },
            "value": "",
            "hint": {
                "en": "Shows the type of gateway.",
                "de": "Zeigt den Gateway-Typ."
            }
        },
        {
            "id": "batteryType",
            "type": "dropdown",
            "label": {
                "en": "Battery Type",
                "nl": "Type batterij",
                "de": "Batterietyp"
            },
            "value": "0",
            "hint": {
                "en": "Specify the battery type for the correct % estimation. The setting will take affect on the next status update.",
                "nl": "Geef het batterijtype op voor de juiste %-schatting. De instelling wordt van kracht bij de volgende statusupdate.",
                "de": "Batterietyp angeben, um eine korrekte %-Schätzung zu erhalten. Die Einstellung wird bei der nächsten Statusaktualisierung wirksam."
            },
            "values": [
                {
                    "id": "0",
                    "label": {
                        "en": "Non-rechargeable",
                        "nl": "Niet oplaadbaar",
                        "de": "Nicht aufladbar"
                    }
                },
                {
                    "id": "1",
                    "label": {
                        "en": "Rechargeable",
                        "nl": "Oplaadbaar",
                        "de": "Aufladbar"
                    }
                }
            ]
        },
		{
			"id": "stationType",
			"type": "label",
			"label": {
				"en": "Station Type",
				"de": "Stationstyp"
			},
			"value": "",
			"hint": {
				"en": "Shows the type of gateway.",
				"de": "Zeigt den Stationstyp"
			}
		},
		{
			"id": "ignorePiezo",
			"type": "checkbox",
			"label": {
				"en": "Ignore Piezo",
				"de": "Piezo ignorieren"
			},
			"value": false,
			"hint": {
				"en": "If enabled, the driver will ignore the Piezo rain sensor data and only use the standard rain sensor data.",
				"de": "Wenn aktiviert, ignoriert der Treiber die Daten des Piezo-Regenmessers und verwendet nur die Daten des Standard-Regenmessers."
			}
		}
    ],
    "images": {
        "small": "/drivers/weather_station/assets/images/small.png",
        "large": "/drivers/weather_station/assets/images/large.png"
    }
}
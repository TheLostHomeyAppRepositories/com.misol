                "de": "Taupunkt"
            },
            "decimals": 1
        },
        "measure_rain.rate": {
            "title": {
                "en": "Rain Rate",
                "nl": "Regenintensiteit",
                "de": "Regenrate"
            },
            "units": {
                "en": "mm/hr",
                "nl": "mm/u",
                "de": "mm/h"
            }
        },
        "measure_rain.event": {
            "title": {
                "en": "Rain Event",
                "nl": "Regenbui",
                "de": "Regenereignis"
            }
        },
        "measure_rain.hourly": {
            "title": {
                "en": "Rain Hourly",

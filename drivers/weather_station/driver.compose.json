{
    "name": {
        "en": "Weather Station",
        "nl": "Weerstation",
        "de": "Wetterstation"
    },
    "platforms": [
        "local"
    ],
    "connectivity": [
        "lan"
    ],
    "class": "sensor",
    "capabilities": [
        "measure_temperature",
        "measure_humidity",
        "measure_temperature.feelsLike",
        "measure_temperature.dewPoint",
        "measure_pressure",
        "measure_wind_angle",
        "measure_wind_direction",
        "measure_wind_strength",
        "measure_gust_strength",
        "measure_gust_strength.daily",
        "measure_radiation",
        "measure_luminance",
        "measure_ultraviolet",
        "measure_rain.rate",
        "measure_rain.event",
        "measure_rain.hourly",
        "measure_rain.daily",
        "measure_rain.weekly",
        "measure_rain.monthly",
        "measure_rain.yearly",
        "measure_rain.total",
        "measure_hours_since_rained",
        "alarm_battery",
        "measure_battery"
    ],
